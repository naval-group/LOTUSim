<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>simulation_control</name>
  <version>0.0.0</version>
  <description>This package is suposed to expose services to the user so that he can have runtime
    control over the simulation. For now, these services can be called from RQT Service Caller, but
    a UI can later be implemented.</description>
  <maintainer email="kfiter.exterieur@pacific.naval-group.com">Kerian Fiter</maintainer>
  <license>TODO: License declaration</license>
  <author email="kfiter.exterieur@pacific.naval-group.com">Kerian Fiter</author>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>ament_index_cpp</depend>
  <depend>liquidai_msgs</depend>
  <depend>lifecycle_msgs</depend>
  <depend>std_srvs</depend>
  <depend>rclcpp_components</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>