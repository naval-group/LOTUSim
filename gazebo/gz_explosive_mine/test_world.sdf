<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">
    <model name="Mine">
      <pose>0 0 10 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </collision>
        <sensor name='sensor_contact' type='contact'>
          <contact>
            <collision>collision</collision>
          </contact>
        </sensor>
      </link>
      <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"></plugin>
      <plugin filename="ExplosiveMine" name="mine::ExplosiveMine">
        <targets>
          <item>ground_plane</item>
        </targets>
        <namespace>mine</namespace>
        <time>0.001</time>
        <enabled>true</enabled>
      </plugin>
    </model>
    <model name="Mine2">
      <pose>0 10 20 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </collision>
        <sensor name='sensor_contact' type='contact'>
          <contact>
            <collision>collision</collision>
          </contact>
        </sensor>
      </link>
      <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"></plugin>
      <plugin filename="ExplosiveMine" name="mine::ExplosiveMine">
        <targets>
          <item>ground_plane</item>
        </targets>
        <colors>
            <r>0.0</r>
            <g>0.0</g>
            <b>1.0</b>
            <a>1.0</a>
        </colors>
        <namespace>mine</namespace>
        <time>0.001</time>
        <enabled>true</enabled>
      </plugin>
    </model>
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>
  </world>
</sdf>