<?xml version="1.0"?>
<package format="2">
  <name>WindAdjusterPlugin</name>
  <version>0.1.0</version>
  <description>Wind Adjuster Plugin for Gazebo simulation with Qt interface</description>
  <maintainer email="malcom.neo@fe.naval-group.com">malcom neo</maintainer>
  
  <author email="jakepell501@gmail.com">jacob borthwick-pellissier</author>
  <author email="hlechene.exterieur@pacific.naval-group.com">helene lechene</author>
  <author email="malcom.neo@fe.naval-group.com">malcom neo</author>


  <license>Apache-2.0</license>
  <!-- Build system dependencies -->
  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- Run dependencies -->
  <exec_depend>gz-sim8</exec_depend>
  <exec_depend>gz-transport</exec_depend>
  <exec_depend>gz-msgs</exec_depend>
  <exec_depend>Qt5</exec_depend>

  <!-- Test dependencies (optional) -->
  <test_depend>ament_lint</test_depend>

  <!-- Dependencies required for building the plugin -->
  <build_depend>ament_cmake</build_depend>
  <build_depend>Qt5Core</build_depend>
  <build_depend>Qt5Widgets</build_depend>
  <build_depend>Qt5Qml</build_depend>

  <!-- Export section for possible ament index or other configurations -->
  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
