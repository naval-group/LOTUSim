      <instance_effect url="#Material-effect"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="Cube-mesh" name="Cube">
      <mesh>
        <source id="Cube-mesh-positions">
          <float_array id="Cube-mesh-positions-array" count="24">250 250 0 250 250 -128 250 -250 0 250 -250 -128 -250 250 0 -250 250 -128 -250 -250 0 -250 -250 -128</float_array>
          <technique_common>
            <accessor source="#Cube-mesh-positions-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="Cube-mesh-normals">
          <float_array id="Cube-mesh-normals-array" count="24">0 1 0 1 0 0 -1 0 0 0 -1 0 0 1 0 1 0 0 -1 0 0 0 -1 0</float_array>
          <technique_common>
            <accessor source="#Cube-mesh-normals-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="Cube-mesh-map-0">
          <float_array id="Cube-mesh-map-0-array" count="48">0.375 1 0.625 0.75 0.375 0.75 0.375 0.25 0.625 0 0.375 0 0.375 0.75 0.625 0.5 0.375 0.5 0.375 0.5 0.625 0.25 0.375 0.25 0.375 1 0.625 1 0.625 0.75 0.375 0.25 0.625 0.25 0.625 0 0.375 0.75 0.625 0.75 0.625 0.5 0.375 0.5 0.625 0.5 0.625 0.25</float_array>
