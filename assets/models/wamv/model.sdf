            <uri>model://wamv/meshes/propeller.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name='right_chasis_engine_joint' type='fixed'>
      <pose relative_to='base_link'>-2.373776 -1.027135 0.318237 0 0 0</pose>
      <parent>base_link</parent>
