                  <stddev>7.8</stddev>
              </noise>
            </vertical>
          </position_sensing>
          <velocity_sensing>
            <horizontal>
              <noise type="gaussian">
                  <mean>9.1</mean>
                  <stddev>10.11</stddev>
              </noise>
            </horizontal>
            <vertical>
              <noise type="gaussian">
                  <mean>12.13</mean>
                  <stddev>14.15</stddev>
              </noise>
            </vertical>
          </velocity_sensing>
        </gps> -->
      </sensor>
    </link>
    <joint name='navsat_base_joint' type='fixed'>
      <pose relative_to='base_link'>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>navsat_sensor</child>
    </joint>

    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <namespace>wamv</namespace>
      <joint_name>left_engine_propeller_joint</joint_name>
      <thrust_coefficient>0.004422</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.48</propeller_diameter>
      <max_thrust_cmd>2000.0</max_thrust_cmd>
      <min_thrust_cmd>-2000.0</min_thrust_cmd>
