<?xml version="1.0"?>
<sdf version="1.7">

  <model name='wamv'>
    <link name="base_link">
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://wamv/meshes/WAM-V-Base.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://wamv/meshes/wam-v-base_collision_406.stl</uri>
          </mesh>
        </geometry>
      </collision>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>180</mass>
        <inertia>
          <ixx>120</ixx>
          <ixy>0</ixy>
          <iyy>393</iyy>
          <iyz>0</iyz>
          <izz>446</izz>
        </inertia>
      </inertial>
    </link>

    <joint name='gps_wamv_joint' type='revolute'>
      <pose relative_to='base_link'>-0.85 0 1.3 0 0 0</pose>
      <parent>base_link</parent>
      <child>gps_wamv_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0</upper>
          <effort>1000</effort>
          <velocity>0</velocity>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='gps_wamv_link'>
      <pose relative_to='gps_wamv_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.0064580000000000002</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0064580000000000002</iyy>
          <iyz>0</iyz>
          <izz>0.01125</izz>
        </inertia>
      </inertial>
      <visual name='gps_wamv_link_fixed_joint_lump__gps_wamv_visual_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://wamv/meshes/gps.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name='imu_wamv_joint' type='revolute'>
      <pose relative_to='base_link'>0.3 -0.2 1.3 0 0 0</pose>
      <parent>base_link</parent>
      <child>imu</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0</upper>
          <effort>1000</effort>
          <velocity>0</velocity>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='imu'>
      <pose relative_to='imu_wamv_joint'>0 0 0 0 0 0</pose>
      <visual name='imu_wamv_link_fixed_joint_lump__imu_wamv_visual_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.05 0.025 0.005</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 0 0 1</diffuse>
          <ambient>1 0 0 1</ambient>
        </material>
      </visual>
      <sensor name="imu_wamv_link" type="imu">
        <always_on>1</always_on>
        <update_rate>60</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
        <ignition_frame_id>wamv/imu/imu_wamv_link</ignition_frame_id>
        <enable_metrics>true</enable_metrics>
        <imu>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>1</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </z>
          </linear_acceleration>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </z>
          </angular_velocity>
          <orientation_reference_frame>
            <localization>ENU</localization>
            <custom_rpy parent_frame="linka">0 1 0</custom_rpy>
            <grav_dir_x parent_frame="linkb">0 0 1</grav_dir_x>
          </orientation_reference_frame>
          <enable_orientation>true</enable_orientation>
        </imu>
      </sensor>
      <sensor name="magnetometer" type="magnetometer">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>magnetometer</topic>
        <enable_metrics>true</enable_metrics>
        <magnetometer>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </z>
        </magnetometer>
      </sensor>
    </link>
    <joint name='left_chasis_engine_joint' type='fixed'>
      <pose relative_to='base_link'>-2.373776 1.027135 0.318237 0 0 0</pose>
      <parent>base_link</parent>
      <child>left_engine_link</child>
    </joint>
    <link name='left_engine_link'>
      <pose relative_to='left_chasis_engine_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>15</mass>
        <inertia>
          <ixx>0.88924499999999995</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.91112499999999996</iyy>
          <iyz>0</iyz>
          <izz>0.078125</izz>
        </inertia>
      </inertial>
      <collision name='left_engine_link_fixed_joint_lump__left_engine_vertical_axis_collision_collision'>
        <pose>-0.16 0 -0.24 0 0 0</pose>
        <geometry>
          <box>
            <size>0.2 0.15 0.83</size>
          </box>
        </geometry>
      </collision>
      <collision name='left_engine_link_fixed_joint_lump__left_engine_rear_end_collision_collision_1'>
        <pose>-0.34 0 0.12 0 0 0</pose>
        <geometry>
          <box>
            <size>0.12 0.15 0.12</size>
          </box>
        </geometry>
      </collision>
      <visual name='left_engine_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://wamv/meshes/engine.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name='left_engine_propeller_joint' type='revolute'>
      <pose relative_to='left_engine_link'>-0.278156 0 -0.509371 0 0 0</pose>
      <parent>left_engine_link</parent>
      <child>thruster_0</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <effort>100</effort>
          <velocity>100</velocity>
          <lower>-10000000000000000</lower>
          <upper>10000000000000000</upper>
        </limit>
        <dynamics>
          <damping>0.050000000000000003</damping>
          <friction>0.050000000000000003</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='thruster_0'>
      <pose relative_to='left_engine_propeller_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0085450000000000005</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0085450000000000005</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name='left_propeller_link_fixed_joint_lump__left_propeller_collision_collision'>
        <pose>-0.08 0 0 0 1.570796326794897 0</pose>
        <geometry>
          <cylinder>
            <length>0.17999999999999999</length>
            <radius>0.23999999999999999</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='left_propeller_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
