    <link name='front_camera'>
      <pose>0.7181244477324606 0.3 1.508541028488383 0 0 0</pose>
      <sensor name="front_camera" type="camera">
        <camera>  
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>320</width>
            <height>240</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>front_camera</topic>
      </sensor>
    </link>
    <joint name='front_camera_base_joint' type='fixed'>
      <pose relative_to='base_link'>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>front_camera</child>
    </joint>

    <link name="front_left_camera">
      <pose>0.7181244477324606 0.1 1.508541028488383 0 0 0</pose>
      <sensor name="front_left_camera" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>320</width>
            <height>240</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
        <always_on>1</always_on>
