    </link>
    <joint name='front_right_camera_base_joint' type='fixed'>
      <pose relative_to='base_link'>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>front_right_camera</child>
    </joint>

    <link name="middle_right_camera">
      <pose>0.5 -0.4181244477324608 1.508541028488383 0 0 -1.57</pose>
      <sensor name="middle_right_camera" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
