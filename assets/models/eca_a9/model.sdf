<?xml version="1.0"?>
<sdf version="1.6">
  <model name="eca_a9">
    <!-- Body -->
    <link name="base_link">
      <inertial>
        <mass>210.9020</mass>
        <inertia>
          <ixx>10.6</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>30.0</iyy>
          <iyz>0.0</iyz>
          <izz>35.0</izz>
        </inertia>
      </inertial>
      <!-- Uncomment this block to enable neutral buoyancy. -->
      <collision name="main_body_buoyancy">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9.stl </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <sensor name="imu_wamv_link" type="imu">
        <always_on>1</always_on>
        <update_rate>60</update_rate>
        <visualize>true</visualize>
        <topic>eca/imu</topic>
        <gz_frame_id>eca/base_link</gz_frame_id>
        <enable_metrics>true</enable_metrics>
        <imu>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>1</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </z>
          </linear_acceleration>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0</stddev>
                <dynamic_bias_stddev>0.2</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>1</dynamic_bias_correlation_time>
              </noise>
            </z>
          </angular_velocity>
          <orientation_reference_frame>
            <localization>ENU</localization>
            <custom_rpy parent_frame="linka">0 1 0</custom_rpy>
            <grav_dir_x parent_frame="linkb">0 0 1</grav_dir_x>
          </orientation_reference_frame>
          <enable_orientation>true</enable_orientation>
        </imu>
      </sensor>
      <sensor name="magnetometer" type="magnetometer">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>eca/magnetometer</topic>
        <gz_frame_id>eca/base_link</gz_frame_id>
        <enable_metrics>true</enable_metrics>
        <magnetometer>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </z>
        </magnetometer>
      </sensor>
    </link>

    <!-- Fin -->
    <link name="fin0">
      <pose>-0.70777 -0.07876 0.078586 0.7904 -0.0998 -0.1003</pose>
      <inertial>
        <mass>0.192</mass>
      </inertial>
      <visual name="fin0_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="collision_fin0">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
    <joint name="fin0_joint" type="revolute">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>fin0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.39626</lower>
          <upper>1.39626</upper>
          <velocity>0</velocity>
        </limit>
      </axis>
    </joint>

    <link name="fin1">
      <pose>-0.70777 -0.07876 -0.078586 2.3512 0.0998 -0.1003</pose>
      <inertial>
        <mass>0.192</mass>
      </inertial>
      <visual name="fin1_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="collision_fin1">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
    <joint name="fin1_joint" type="revolute">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>fin1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.39626</lower>
          <upper>1.39626</upper>
          <velocity>0</velocity>
        </limit>
      </axis>
    </joint>

    <link name="fin2">
      <pose>-0.70777 0.07876 -0.078586 -2.3512 0.0998 0.1003</pose>
      <inertial>
        <mass>0.192</mass>
      </inertial>
      <visual name="fin2_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="collision_fin2">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
    <joint name="fin2_joint" type="revolute">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>fin2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.39626</lower>
          <upper>1.39626</upper>
          <velocity>0</velocity>
        </limit>
      </axis>
    </joint>

    <link name="fin3">
      <pose>-0.70777 0.07876 0.078586 -0.7904 -0.0998 0.1003</pose>
      <inertial>
        <mass>0.192</mass>
      </inertial>
      <visual name="fin3_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="collision_fin3">
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_fin.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
    <joint name="fin3_joint" type="revolute">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>fin3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.39626</lower>
          <upper>1.39626</upper>
          <velocity>0</velocity>
        </limit>
      </axis>
    </joint>

    <!-- Thruster-->
    <link name="propeller">
      <pose>-0.9676 0 0 0 0 3.1415</pose>
      <inertial>
        <mass>0.00001</mass>
      </inertial>
      <visual name="propeller_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri> model://eca_a9/mesh/eca_a9_propeller.dae </uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="propeller_collision">
        <geometry>
          <cylinder>
            <length>0.000001</length>
            <radius>0.000001</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>
    <joint name="propeller_joint" type="revolute">
      <pose>0 0 0 0 0 3.145</pose>
      <parent>base_link</parent>
      <child>propeller</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e+12</lower>
          <upper>1e+12</upper>
          <effort>-1</effort>
          <velocity>-1</velocity>
        </limit>
      </axis>
    </joint>

    <!-- Start of plugin -->
    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <use_angvel_cmd>0</use_angvel_cmd>
      <joint_name>propeller_joint</joint_name>
      <thrust_coefficient>0.004422</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.2</propeller_diameter>
    </plugin>

    <!-- The Lift acting on the controlled surfaces -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <air_density>1000</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0244</area>
      <upward>0 1 0</upward>
      <forward>1 0 0</forward>
      <link_name>fin0</link_name>
      <cp>0 0 0</cp>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <air_density>1000</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0244</area>
      <upward>0 0 1</upward>
      <forward>1 0 0</forward>
      <link_name>fin1</link_name>
      <cp>0 0 0</cp>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <air_density>1000</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0244</area>
      <upward>0 0 1</upward>
      <forward>1 0 0</forward>
      <link_name>fin2</link_name>
      <cp>0 0 0</cp>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <air_density>1000</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0244</area>
      <upward>0 0 1</upward>
      <forward>1 0 0</forward>
      <link_name>fin3</link_name>
      <cp>0 0 0</cp>
    </plugin>

    <!-- The movement of the controlled surfaces -->
    <plugin filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>fin0_joint</joint_name>
      <p_gain>0.1</p_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>fin1_joint</joint_name>
      <p_gain>0.1</p_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>fin2_joint</joint_name>
      <p_gain>0.1</p_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>fin3_joint</joint_name>
      <p_gain>0.1</p_gain>
    </plugin>
  </model>
</sdf>